{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false
    },
    "MD033": {
      "allowed_elements": ["br", "sub", "sup", "kbd", "details", "summary"]
    },
    "MD041": false,
    "MD024": {
      "siblings_only": true
    }
  },
  "globs": [
    "**/*.md"
  ],
  "ignores": [
    "node_modules/**",
    "venv/**",
    "dist/**",
    "build/**",
    ".turbo/**"
  ]
}